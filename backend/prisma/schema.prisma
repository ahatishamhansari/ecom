// This is your Prisma schema file for StyleForge
// Handles: Users, Auth, Orders, Payments, Inventory, FitDNA, SizeIntelligence

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  role         Role     @default(CUSTOMER)
  isVerified   Boolean  @default(false)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  fitDna       FitDna?
  addresses    Address[]
  orders       Order[]
  cartItems    CartItem[]
  reviews      Review[]
  fitFeedback  FitFeedback[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─── FitDNA (Biometric Fit Profile) ──────────────────────────────────────────

model FitDna {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Body measurements (cm)
  height          Float?
  weight          Float?
  chest           Float?
  waist           Float?
  hips            Float?
  inseam          Float?
  shoulderWidth   Float?
  armLength       Float?

  // Shoe sizing
  shoeSize        Float?
  shoeSizeSystem  String? @default("UK") // UK, US, EU

  // Body shape classification (from CV model)
  bodyShape       String? // hourglass, pear, apple, rectangle, inverted_triangle

  // Fit preferences
  fitPreference   String? @default("regular") // slim, regular, relaxed, oversized

  // Raw measurement photo (processed, not stored permanently)
  isPhotoProcessed Boolean @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("fit_dna")
}

// ─── Addresses ───────────────────────────────────────────────────────────────

model Address {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String? @default("Home") // Home, Work, etc.
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String  @default("IN")
  isDefault  Boolean @default(false)

  orders     Order[]

  @@map("addresses")
}

// ─── Orders ──────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURNED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  addressId       String
  address         Address       @relation(fields: [addressId], references: [id])

  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)

  subtotal        Decimal       @db.Decimal(10, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(10, 2)
  shippingAmount  Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(10, 2)

  couponCode      String?
  notes           String?

  stripePaymentId String?
  stripeSessionId String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items           OrderItem[]
  payment         Payment?
  fitFeedback     FitFeedback[]

  @@map("orders")
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // MongoDB product reference (stored as string IDs)
  productId    String
  variantId    String
  productName  String
  variantName  String
  sku          String
  imageUrl     String?

  quantity     Int
  unitPrice    Decimal @db.Decimal(10, 2)
  totalPrice   Decimal @db.Decimal(10, 2)

  @@map("order_items")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id])
  gateway         String        @default("stripe") // stripe, razorpay
  gatewayId       String?
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("INR")
  status          PaymentStatus @default(PENDING)
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("payments")
}

// ─── Cart (Persistent) ────────────────────────────────────────────────────────

model CartItem {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String   // MongoDB reference
  variantId  String   // MongoDB reference
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, variantId])
  @@map("cart_items")
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String   // MongoDB reference
  rating    Int      // 1-5
  title     String?
  body      String?
  images    String[] // Array of image URLs
  isVerifiedPurchase Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}

// ─── SizeIntelligence Feedback ────────────────────────────────────────────────

enum FitRating {
  TOO_SMALL
  SLIGHTLY_SMALL
  PERFECT
  SLIGHTLY_LARGE
  TOO_LARGE
}

model FitFeedback {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  orderId    String
  order      Order     @relation(fields: [orderId], references: [id])
  productId  String    // MongoDB reference
  variantId  String    // MongoDB reference
  sizePurchased String
  fitRating  FitRating
  comment    String?
  createdAt  DateTime  @default(now())

  @@unique([userId, variantId, orderId])
  @@map("fit_feedback")
}

// ─── Inventory (PostgreSQL for strict stock control) ──────────────────────────

model Inventory {
  id           String   @id @default(cuid())
  variantId    String   @unique // MongoDB variant reference
  sku          String   @unique
  quantity     Int      @default(0)
  reservedQty  Int      @default(0) // reserved during checkout
  lowStockAt   Int      @default(5) // alert threshold
  updatedAt    DateTime @updatedAt

  @@map("inventory")
}

// ─── Dynamic Entity Builder (EAV / JSONB Schema) ──────────────────────────────

model DynamicEntity {
  id          String   @id @default(cuid())
  entityKey   String   @unique // e.g., "PRODUCT"
  name        String
  description String?
  isActive    Boolean  @default(true)
  fieldSchema Json     // Array of field definitions (name, type, required, options)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  rows        DynamicEntityRow[]

  @@map("dynamic_entities")
}

model DynamicEntityRow {
  id              String   @id @default(cuid())
  dynamicEntityId String
  entity          DynamicEntity @relation(fields: [dynamicEntityId], references: [id], onDelete: Cascade)
  rowData         Json     // The actual values corresponding to the fieldSchema
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("dynamic_entity_rows")
}
